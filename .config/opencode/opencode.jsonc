{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "nous-portal": {
      "name": "Nous Portal",
      "api": "openai",
      "env": ["NOUS_PORTAL_API_KEY"],
      "options": {
        "apiKey": "${NOUS_PORTAL_API_KEY}",
        "baseURL": "https://inference-api.nousresearch.com/v1"
      },
      "models": {
        "Hermes-4-70B": {
          "name": "Hermes 4 70B",
          "limit": { "context": 128000, "output": 32000 },
          "cost": { "input": 0.00000005, "output": 0.00000020 },
          "tool_call": true,
          "reasoning": true
        },
        "Hermes-4-405B": {
          "name": "Hermes 4 405B",
          "limit": { "context": 128000, "output": 32000 },
          "cost": { "input": 0.00000009, "output": 0.00000037 },
          "tool_call": true,
          "reasoning": true
        }
      }
    }
  }
}